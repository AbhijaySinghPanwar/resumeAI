# .env — Local development environment variables for ResumeAI
# DO NOT commit this file to version control with real secrets.
# Copy this file and fill in real values.

# Application
APP_NAME=ResumeAI
APP_VERSION=4.0.0
ENVIRONMENT=development
DEBUG=true

# Security — CHANGE THIS in production!
SECRET_KEY=dev-secret-key-change-in-production-please-make-it-long-and-random

# JWT
JWT_EXPIRE_MINUTES=10080

# Database — SQLite by default (zero-config). Use PostgreSQL in production:
# DATABASE_URL=postgresql://user:password@localhost:5432/resumeai
DATABASE_URL=sqlite:///./resumeai.db

# Gemini API Key — set your real key here
GEMINI_API_KEY=your-gemini-api-key-here
